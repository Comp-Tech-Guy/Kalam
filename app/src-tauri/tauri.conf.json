{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kalam",
  "version": "0.1.0",
  "identifier": "Kalam",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Comp-Tech-Guy/Kalam/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBMzFCMTkwOTYzQUIyQTUKUldTbHNqcVdrTEV4dWdRYUFRTitkY1dSZVBNODU5MWZRWGR4YldYVU45UHNTNDI2V0hqYWtWNmIK"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kalam",
        "width": 1000,
        "height": 800,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "decorations": false,
        "center": true,
        "minWidth": 700,
        "minHeight": 500,
        "backgroundColor": "#0D0F12"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' asset:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 ws://localhost:1421"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/my-sidecar/kalam-Sidecar"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
